\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{lualatex-report-base}

% === 基本設定 ===
\RequirePackage{graphicx, xcolor}       % 画像の挿入・文字色
\RequirePackage{tikz}

% === フォント設定 ===
\RequirePackage{unicode-math}
\RequirePackage{luatexja-fontspec}

% --- 欧文・数式設定 ---
\setmainfont{TeX Gyre Termes}
\setsansfont{TeX Gyre Heros}[Scale=MatchLowercase]
\setmathfont{TeX Gyre Termes Math}

% --- 和文設定 ---
\RequirePackage[haranoaji, deluxe]{luatexja-preset}

% === レイアウト・装飾 ===
\RequirePackage{geometry}
\pagestyle{plain}                   % フッター中央にページ数
\RequirePackage{float}
\RequirePackage{multirow}               % 列の結合
\RequirePackage{booktabs}               % きれいな表の罫線
\RequirePackage{tabularx}               % 表の幅自動調整
\RequirePackage{enumitem}               % 箇条書きの高度な制御
\RequirePackage[normalem]{ulem}         % 強調を上書きしない設定
\RequirePackage{tcolorbox}              % 文章囲み
\tcbuselibrary{breakable}           % tcolorboxのページ跨ぎ
\RequirePackage[mathlines]{lineno}
\RequirePackage{listings}               % プログラムコードの貼り付け

% === 数式・物理 ===
\RequirePackage{amsmath}                % 数学記号・環境
\RequirePackage{physics}                % 物理系記号
\RequirePackage{siunitx}                % SI単位系の統一表記
\AtBeginDocument{\RenewCommandCopy\qty\SI}  % physicsとの競合回避

% === 図表・式の番号設定 ===
\RequirePackage[compatibility=false, font=small, labelfont=bf]{caption}
\RequirePackage{subcaption}             % 図の並列配置

% === リンク・参照 ===
\RequirePackage{url}                    % URLを綺麗に表示
\RequirePackage{cleveref}               % 参照

% --- cleverefの日本語設定 ---
\crefname{equation}{式}{式}
\crefname{figure}{図}{図}
\crefname{table}{表}{表}
\crefname{page}{ページ}{ページ}
\crefname{section}{節}{節}
\crefname{appendix}{付録}{付録}
\creflabelformat{equation}{#2#1#3}

% === その他 ===
\RequirePackage{pxrubrica}              % ルビ振り